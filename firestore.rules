rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para determinar si el usuario autenticado tiene rol de admin
    function isAdmin() {
      // Nota: get() cuenta como una lectura en Firestore.
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }

    match /users/{userId} {
      // Un usuario solo puede leer/editar su propio documento.
      // El administrador lee todos. (y se asume puede escribir para gestionar roles, aunque la regla pide 'admin lee todos', es buena práctica permitirle gestionar).
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    match /mesas/{mesaId} {
      // Cualquier usuario (incluso no autenticado) puede leer (para ver el mapa).
      allow read: if true;
      
      // Solo rol == "admin" puede escribir/modificar capacidades o bloquearlas (estado 3).
      // (Nota: Para la lógica de soft-lock que el cliente pasa la mesa de 0 a 1, si se debe hacer desde frontend por el cliente, requeriría una condición adicional para la actualización del estado. Se implementa aquí la base que permite cambio de 0 a 1 por usuarios autenticados como soft lock).
      allow update: if isAdmin() || (
        request.auth != null && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado']) && 
        resource.data.estado == 0 && request.resource.data.estado == 1
      );
      allow create, delete: if isAdmin();
    }

    match /reservas/{reservaId} {
      // Un cliente solo puede leer y crear reservas donde su uid coincida.
      allow read: if (request.auth != null && resource.data.uid_cliente == request.auth.uid) || isAdmin();
      allow create: if (request.auth != null && request.resource.data.uid_cliente == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
