rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isBootstrapProgramador() {
      return signedIn() &&
        request.auth.token.email == 'angelarmentta@icloud.com' &&
        request.auth.token.email_verified == true;
    }

    function userDocExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return isBootstrapProgramador() ? 'programador' :
        (userDocExists() && userData().rol is string ? userData().rol : 'cliente');
    }

    function userPermissions() {
      return userDocExists() && userData().permissions is list ? userData().permissions : [];
    }

    function rolePermissions() {
      return signedIn() &&
        exists(/databases/$(database)/documents/roles/$(userRole())) &&
        get(/databases/$(database)/documents/roles/$(userRole())).data.permissions is list
          ? get(/databases/$(database)/documents/roles/$(userRole())).data.permissions
          : [];
    }

    function directPermissions() {
      return signedIn() &&
        exists(/databases/$(database)/documents/userPermissions/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userPermissions/$(request.auth.uid)).data.permissions is list
          ? get(/databases/$(database)/documents/userPermissions/$(request.auth.uid)).data.permissions
          : [];
    }

    function hasDefaultPermission(permission) {
      return userRole() == 'programador' ||
        (userRole() == 'trabajador' && [
          'dashboard.manage',
          'tickets.monitor',
          'tickets.scan',
          'inventory.adjust',
          'sales.physical',
          'parking.manage'
        ].hasAny([permission])) ||
        (userRole() == 'jefe' && [
          'dashboard.manage',
          'tickets.monitor',
          'tickets.scan',
          'packages.manage',
          'landing.manage',
          'finance.view',
          'admin.panel',
          'inventory.manage',
          'inventory.adjust',
          'sales.physical',
          'parking.manage'
        ].hasAny([permission]));
    }

    function hasPermission(permission) {
      return signedIn() && (
        isBootstrapProgramador() ||
        userRole() == 'programador' ||
        hasDefaultPermission(permission) ||
        userPermissions().hasAny([permission]) ||
        rolePermissions().hasAny([permission]) ||
        directPermissions().hasAny([permission])
      );
    }

    function isOwnUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validOwnUserCreate(userId) {
      return isOwnUser(userId) &&
        request.resource.data.keys().hasOnly([
          'email',
          'nombre',
          'photoURL',
          'providerId',
          'rol',
          'permissions',
          'createdAt',
          'updatedAt',
          'lastLoginAt'
        ]) &&
        request.resource.data.rol == 'cliente' &&
        (!request.resource.data.keys().hasAny(['permissions']) || request.resource.data.permissions == []);
    }

    function validBootstrapProgramadorWrite(userId) {
      return isOwnUser(userId) &&
        isBootstrapProgramador() &&
        request.resource.data.keys().hasOnly([
          'email',
          'nombre',
          'photoURL',
          'providerId',
          'rol',
          'permissions',
          'createdAt',
          'updatedAt',
          'lastLoginAt'
        ]) &&
        request.resource.data.rol == 'programador';
    }

    function validOwnUserUpdate(userId) {
      return isOwnUser(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email',
          'nombre',
          'photoURL',
          'providerId',
          'updatedAt',
          'lastLoginAt'
        ]);
    }

    match /users/{userId} {
      allow read: if isOwnUser(userId) || hasPermission('users.permissions');
      allow create: if validBootstrapProgramadorWrite(userId) || validOwnUserCreate(userId) || hasPermission('users.permissions');
      allow update: if validBootstrapProgramadorWrite(userId) || validOwnUserUpdate(userId) || hasPermission('users.permissions');
      allow delete: if hasPermission('users.permissions');
    }

    match /roles/{roleId} {
      allow read: if signedIn();
      allow write: if hasPermission('roles.manage');
    }

    match /userPermissions/{userId} {
      allow read: if isOwnUser(userId) || hasPermission('users.permissions');
      allow write: if hasPermission('users.permissions');
    }

    match /appConfig/{docId} {
      allow read: if true;
      allow write: if docId == 'theme' && hasPermission('theme.manage');
    }

    match /mesas/{mesaId} {
      allow read: if true;
      allow update: if hasPermission('dashboard.manage') || (
        signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado']) &&
        resource.data.estado == 0 && request.resource.data.estado == 1
      );
      allow create, delete: if hasPermission('admin.panel');
    }

    match /reservas/{reservaId} {
      allow read: if (signedIn() && resource.data.uid_cliente == request.auth.uid) || hasPermission('tickets.monitor');
      allow create: if (signedIn() && request.resource.data.uid_cliente == request.auth.uid) || hasPermission('tickets.monitor');
      allow update, delete: if hasPermission('tickets.monitor');
    }

    match /configuracion/{docId} {
      allow read: if true;
      allow write: if hasPermission('admin.panel');
    }

    match /paquetes/{paqueteId} {
      allow read: if true;
      allow write: if hasPermission('packages.manage');
    }

    match /descuentos/{codigo} {
      allow read: if true;
      allow write: if hasPermission('packages.manage');
    }

    match /tickets/{ticketId} {
      allow create: if true;
      allow read: if hasPermission('tickets.monitor') || (signedIn() && resource.data.cliente_uid == request.auth.uid);
      allow update: if hasPermission('tickets.scan') || hasPermission('tickets.monitor');
      allow delete: if hasPermission('admin.panel');
    }

    // Estacionamiento: lectura publica (landing), escritura solo personal autorizado
    match /parkingSpots/{spotId} {
      allow read: if true;
      allow create, update, delete: if signedIn() && hasPermission('parking.manage');
    }

    // Canal realtime de mesas por fecha (Fase B).
    // Persistencia canonical sigue en Data Connect; este canal replica estado para UI en vivo.
    match /mesaReservasLive/{rowId} {
      allow read: if true;
      allow create, update: if signedIn() &&
        request.resource.data.keys().hasOnly(['id', 'fechaDia', 'mapItemId', 'userId', 'estado', 'updatedAt']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.estado is string &&
        request.resource.data.fechaDia is string &&
        request.resource.data.mapItemId is string;
      allow delete: if signedIn();
    }

    // Canal ligero para refrescar vistas tras cambios en panel (lectura publica)
    match /appRealtime/{docId} {
      allow read: if true;
      allow create, update: if signedIn() &&
        docId == 'global' &&
        request.resource.data.updatedBy == request.auth.uid;
    }
  }
}
