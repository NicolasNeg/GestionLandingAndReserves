rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para determinar si el usuario autenticado tiene rol de admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }

    // Función auxiliar para personal del parque
    function isStaffOrAdmin() {
      return request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'staff');
    }

    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    match /mesas/{mesaId} {
      allow read: if true;
      allow update: if isAdmin() || (
        request.auth != null && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado']) && 
        resource.data.estado == 0 && request.resource.data.estado == 1
      );
      allow create, delete: if isAdmin();
    }

    // Reservas legacy (si aún se usan)
    match /reservas/{reservaId} {
      allow read: if (request.auth != null && resource.data.uid_cliente == request.auth.uid) || isAdmin();
      allow create: if (request.auth != null && request.resource.data.uid_cliente == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // NUEVAS COLECCIONES - SISTEMA DE TICKETS

    match /configuracion/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /paquetes/{paqueteId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /descuentos/{codigo} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      // Cualquiera puede crear su ticket (checkout público o logueado)
      allow create: if true; 
      // El cliente dueño, o el staff pueden leerlo
      allow read: if isStaffOrAdmin() || (request.auth != null && resource.data.cliente_uid == request.auth.uid);
      // Solo el staff/admin puede actualizar (ej. marcar como 'escaneado' o 'pagado')
      allow update: if isStaffOrAdmin();
      allow delete: if isAdmin();
    }
  }
}
