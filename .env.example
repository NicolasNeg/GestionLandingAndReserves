# --- Firebase (legacy temporal durante migración a Supabase full) ---
# Sin estas variables, firebase-config no inicializa Auth/Firestore/Storage salvo modo Supabase-only parcial.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL de continuación para verificación de correo (Firebase Auth)
VITE_AUTH_CONTINUE_URL=http://localhost:5173/login

# --- Proveedores de subsistema (por defecto = firebase si no existen; reiniciar dev server / redeploy al cambiar) ---
VITE_BACKEND_PROVIDER=firebase
VITE_AUTH_PROVIDER=firebase
VITE_PERMISSIONS_PROVIDER=firebase
VITE_REALTIME_PROVIDER=firebase
VITE_STORAGE_PROVIDER=firebase

# Objetivo Opción B (Supabase full): supabase en cada uno cuando la fase correspondiente esté lista.
# Tras cambiar cualquier VITE_* reinicia `npm run dev`; en hosting (Netlify) hace falta redeploy.

# --- Supabase Auth + Postgres (ej. Fase 5B+) ---
# Google OAuth: en Supabase Dashboard -> Authentication -> Providers -> Google (client id/secret).
# Redirect URLs permitidas: http://localhost:5173/login y tu dominio producción + /login
# VITE_BACKEND_PROVIDER=supabase
# VITE_AUTH_PROVIDER=supabase
# VITE_PERMISSIONS_PROVIDER=supabase
# VITE_REALTIME_PROVIDER=firebase
# VITE_STORAGE_PROVIDER=firebase

# --- Supabase (requerido si VITE_BACKEND_PROVIDER=supabase o VITE_AUTH_PROVIDER=supabase u otros *_PROVIDER=supabase) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=

# EmailJS (opcional)
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=
