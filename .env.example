# =============================================================================
# Proyecto Supabase-only (Postgres + Auth + Realtime + Storage)
# Sin Firebase en producción. Reinicia `npm run dev` tras cambiar variables VITE_*.
# =============================================================================

VITE_BACKEND_PROVIDER=supabase
VITE_AUTH_PROVIDER=supabase
VITE_PERMISSIONS_PROVIDER=supabase
VITE_REALTIME_PROVIDER=supabase
VITE_STORAGE_PROVIDER=supabase

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Bucket único para imágenes (productos/servicios/avatars por prefijo). Crear en Dashboard + políticas.
# VITE_SUPABASE_STORAGE_BUCKET=app-uploads

# Texto del marquee si no hay tema guardado en public.app_theme
# VITE_PROMO_MARQUEE=

# Para enlaces de recuperación / OAuth, incluye https://tu-dominio/login en Redirect URLs de Supabase Auth.
