VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# URL donde Firebase redirige tras verificar el correo (mismo dominio que Hosting; debe estar en Auth > Dominios autorizados)
# Ejemplo produccion: https://gestion-and-landing.web.app/login
VITE_AUTH_CONTINUE_URL=http://localhost:5173/login

# Texto del marquee del header (solo si no hay promoText en Firestore appConfig/theme)
# VITE_PROMO_MARQUEE=Tu mensaje promocional aqui

# EmailJS (opcional): copia del ticket al correo del cliente tras comprar
# Crea servicio + plantilla en https://www.emailjs.com/ y usa las mismas variables en la plantilla.
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=
